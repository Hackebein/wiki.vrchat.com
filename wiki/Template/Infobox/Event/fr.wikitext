<noinclude><languages/></noinclude>
<onlyinclude>
<infobox type="event" theme="community">
	<title source="name"/>
    <image source="image"/>
    <group>
    	<data source="event">
        	<label>Evènement</label>
            <format>[[{{{event}}}]]{{If not template|[[Category:{{{event}}} Events{{#translation:}}]]}}</format>
        </data>
        <data source="organizer">
        	<label>Organisateur</label>
            <format>[[{{{organizer}}}]]{{If not template|[[Category:Events by {{{organizer}}}{{#translation:}}]]}}</format>
        </data>
    	<data source="start">
        	<label>Date de début</label>
            <format>{{#timel:F d, Y|{{{start}}}}}</format>
        </data>
    	<data source="end">
        	<label>Date de fin</label>
            <format>{{#timel:F d, Y|{{{end}}}}}</format>
        </data>
    </group>
	<group layout="horizontal">
    	<header>Chronologie</header>
    	<data source="previous">
        	<label><span style="text-align: left; width: 100%; display: block">[[File:Icons_Arrow_Left.png|frameless|12px|link=]] Event précédent</span></label>
        	<format><span style="text-align: left; width: 100%; display: block">[[Special:MyLanguage/{{{previous}}}|{{{previous}}}]]</span></format>
		</data>
        <data source="next">
        	<label><span style="text-align: right; width: 100%; display: block">Prochain event [[File:Icons_Arrow_Right.png|frameless|12px|link=]]</span></label>
        	<format><span style="text-align: right; width: 100%; display: block">[[Special:MyLanguage/{{{next}}}|{{{next}}}]]</span></format>
		</data>
    </group>
</infobox>{{If not template|[[Category:Events{{#translation:}}]]}}
</onlyinclude>
