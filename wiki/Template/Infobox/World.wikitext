<noinclude><languages/></noinclude><includeonly>{{#if:{{{id|}}}|
{{#ifexist:Template:World/{{{id}}}/name|
<infobox type="World" theme="community">
	<title><default>{{World/{{{id}}}/name}}</default></title>
	<image><default>{{#ifexist:Media:{{{id}}}_imageUrl.png|[[File:{{{id}}}_imageUrl.png]]}}</default></image>
	<group>
        <data><label><translate><!--T:1--> Author</translate></label><default>{{#ifexist:Template:World/{{{id}}}/authorName|{{#ifexist:Template:World/{{{id}}}/authorId|[https://vrchat.com/home/user/{{World/{{{id}}}/authorId}} {{World/{{{id}}}/authorName}}]|{{World/{{{id}}}/authorName}}}}}}</default></data>
        <data source="developers"><label><translate><!--T:2--> Developers</translate></label></data>
        <data><label><translate><!--T:3--> Capacity</translate></label><default>{{#ifexist:Template:World/{{{id}}}/recommendedCapacity|{{#ifexist:Template:World/{{{id}}}/capacity|{{World/{{{id}}}/recommendedCapacity}} (max {{World/{{{id}}}/capacity}})}}}}</default></data>
        <data><label><translate><!--T:4--> Platforms</translate></label><default>{{#ifexist:Template:World/{{{id}}}/platforms|{{World/{{{id}}}/platforms}}}}</default></data>
        <data><label><translate><!--T:5--> Tags</translate></label><default>{{#ifexist:Template:World/{{{id}}}/tags|{{World/{{{id}}}/tags}}}}</default></data>
        <data source="languages"><label><translate><!--T:6--> Languages</translate></label></data>
        <data source="id"><label><translate><!--T:7--> World Link</translate></label>
           <format>{{World link|{{{id}}}|{{#ifexist:Template:World/{{{id}}}/name|{{World/{{{id}}}/name}}|{{{id}}}}}}}</format></data>
        <data><default>{{#ifexist:Template:World/{{{id}}}/previewYoutubeId|<div style="width:248px;margin:0 auto">{{YouTube|id={{World/{{{id}}}/previewYoutubeId}}|width=248px|thumb=File:{{{id}}}_previewYoutubeId.jpg}}</div>}}</default></data>
    </group>
    <group>
        <header>Statistics</header>
        <data><label>Visits</label><default>{{#ifexist:Template:World/{{{id}}}/visits|{{formatnum:{{World/{{{id}}}/visits}}}}}}</default></data>
        <data><label>Favorites</label><default>{{#ifexist:Template:World/{{{id}}}/favorites|{{formatnum:{{World/{{{id}}}/favorites}}}}}}</default></data>
        <data><label>Popularity</label><default>{{#ifexist:Template:World/{{{id}}}/popularity|{{#switch:{{World/{{{id}}}/popularity}}|0=|1=вЭ§пЄП|2=вЭ§пЄПвЭ§пЄП|3=вЭ§пЄПвЭ§пЄПвЭ§пЄП|4=вЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄП|5=вЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄП|6=вЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄП|7=вЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄП|8=вЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄП|9=вЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄП|10=вЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄПвЭ§пЄП}}}}</default></data>
        <data><label>Heat</label><default>{{#ifexist:Template:World/{{{id}}}/heat|{{#switch:{{World/{{{id}}}/heat}}|0=|1=рЯФ•|2=рЯФ•рЯФ•|3=рЯФ•рЯФ•рЯФ•|4=рЯФ•рЯФ•рЯФ•рЯФ•|5=рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•|6=рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•|7=рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•|8=рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•|9=рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•|10=рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•рЯФ•}}}}</default></data>
    </group>
    <group>
        <header><translate><!--T:8--> World history</translate></header>
        <data><label><translate><!--T:9--> Published to Labs</translate></label><default>{{#ifexist:Template:World/{{{id}}}/labsPublicationDate|{{#ifeq:{{World/{{{id}}}/labsPublicationDate}}|none||{{#timel:F d, Y |{{World/{{{id}}}/labsPublicationDate}}}}}}}}</default></data>
        <data><label><translate><!--T:10--> Published</translate></label><default>{{#ifexist:Template:World/{{{id}}}/publicationDate|{{#ifeq:{{World/{{{id}}}/publicationDate}}|none||{{#timel:F d, Y |{{World/{{{id}}}/publicationDate}}}}}}}}</default></data>
        <data><label>Last updated</label><default>{{#ifexist:Template:World/{{{id}}}/updated_at|{{#timel:F d, Y |{{World/{{{id}}}/updated_at}}}}}}</default></data>
        <data><label>Version</label><default>{{#ifexist:Template:World/{{{id}}}/version|{{World/{{{id}}}/version}}}}</default></data>
    </group>
</infobox>
