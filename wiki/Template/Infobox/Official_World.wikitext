<noinclude><languages/></noinclude><includeonly><infobox type="World" theme="official">
	<title source="name"><default>{{#ifexist:Template:World/{{{id|}}}/name|{{World/{{{id|}}}/name}}}}</default></title>
	<image source="image">
	    <caption source="imagecaption" />
	    <default>{{#ifexist:Media:{{{id|}}}_imageUrl.png|[[File:{{{id|}}}_imageUrl.png]]}}</default>
	</image>
	<group>
        <data source="developer"><label><translate><!--T:1--> Developer</translate></label><default>{{#ifexist:Template:World/{{{id|}}}/authorName|{{World/{{{id|}}}/authorName}}}}</default></data>
        <data source="publisher"><label><translate><!--T:2--> Publisher</translate></label></data>
    	<data source="designer"><label><translate><!--T:3--> Designer</translate></label></data>
    	<data source="gen"><label><translate><!--T:4--> Generation</translate></label></data>
        <data source="platform"><label><translate><!--T:5--> Platforms</translate></label><default>{{#ifexist:Template:World/{{{id|}}}/platforms|{{World/{{{id|}}}/platforms}}}}</default></data>
        <data source="themes"><label><translate><!--T:6--> Themes</translate></label></data>
        <data source="link"><label><translate><!--T:7--> World Link</translate></label><default>{{#if:{{{id|}}}|{{World link|{{{id}}}|{{#if:{{{name|}}}|{{{name}}}|{{#ifexist:Template:World/{{{id}}}/name|{{World/{{{id}}}/name}}|{{{id}}}}}}}}}}}</default></data>
        <data source="previewYoutubeId">
           <format><div style="width:248px;margin:0 auto">{{YouTube|id={{{previewYoutubeId}}}|width=248px|thumb=File:{{{id}}}_previewYoutubeId.jpg}}</div></format>
           <default>{{#ifexist:Template:World/{{{id|}}}/previewYoutubeId|<div style="width:248px;margin:0 auto">{{YouTube|id={{World/{{{id|}}}/previewYoutubeId}}|width=248px|thumb=File:{{{id|}}}_previewYoutubeId.jpg}}</div>}}</default></data>
    </group>
    <group>
        <header><translate><!--T:8--> World history</translate></header>
        <data source="labs"><label><translate><!--T:9--> Community Labs</translate></label><default>{{#ifexist:Template:World/{{{id|}}}/labsPublicationDate|{{#ifeq:{{World/{{{id|}}}/labsPublicationDate}}|none||{{#timel:F d, Y |{{World/{{{id|}}}/labsPublicationDate}}}}}}}}</default></data>
        <data source="published"><label><translate><!--T:10--> Published</translate></label><default>{{#ifexist:Template:World/{{{id|}}}/publicationDate|{{#ifeq:{{World/{{{id|}}}/publicationDate}}|none||{{#timel:F d, Y |{{World/{{{id|}}}/publicationDate}}}}}}}}</default></data>
    </group>
</infobox>{{#ifeq: {{NAMESPACENUMBER}} | 0 | [[Category:Worlds{{#translation:}}]] [[Category:Official Content{{#translation:}}]]}}</includeonly><noinclude>{{Documentation}}</noinclude>