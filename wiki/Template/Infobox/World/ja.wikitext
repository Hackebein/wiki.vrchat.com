|image=Vrrat_posed-right.png
|title=<span lang="en" dir="ltr" class="mw-content-ltr">Hang tight…</span>
|description=<span lang="en" dir="ltr" class="mw-content-ltr">World info is still loading — check back in a bit.</span>}}
<infobox type="World" theme="community">
	<title><default><span lang="en" dir="ltr" class="mw-content-ltr">Loading…</span></default></title>
	<image><default>[[File:Placeholder.webp]]</default></image>
	<group>
        <data><label><span lang="en" dir="ltr" class="mw-content-ltr">Author</span></label><default>…</default></data>
        <data source="developers"><label><span lang="en" dir="ltr" class="mw-content-ltr">Developers</span></label></data>
        <data><label><span lang="en" dir="ltr" class="mw-content-ltr">Capacity</span></label><default>…</default></data>
        <data><label><span lang="en" dir="ltr" class="mw-content-ltr">Platforms</span></label><default>…</default></data>
        <data><label><span lang="en" dir="ltr" class="mw-content-ltr">Tags</span></label><default>…</default></data>
        <data><label><span lang="en" dir="ltr" class="mw-content-ltr">Listing</span></label><default>…</default></data>
        <data><label><span lang="en" dir="ltr" class="mw-content-ltr">Content</span></label><default>…</default></data>
        <data source="languages"><label><span lang="en" dir="ltr" class="mw-content-ltr">Languages</span></label></data>
        <data source="id"><label><span lang="en" dir="ltr" class="mw-content-ltr">World Link</span></label>
           <format>{{World link|{{{id}}}|{{{id}}}}}</format></data>
    </group>
    <group>
        <header><span lang="en" dir="ltr" class="mw-content-ltr">Statistics</span></header>
        <data><label><span lang="en" dir="ltr" class="mw-content-ltr">Visits</span></label><default>…</default></data>
        <data><label><span lang="en" dir="ltr" class="mw-content-ltr">Favorites</span></label><default>…</default></data>
        <data><label><span lang="en" dir="ltr" class="mw-content-ltr">Popularity</span></label><default>…</default></data>
        <data><label><span lang="en" dir="ltr" class="mw-content-ltr">Heat</span></label><default>…</default></data>
    </group>
    <group>
        <header><span lang="en" dir="ltr" class="mw-content-ltr">World history</span></header>
        <data><label><span lang="en" dir="ltr" class="mw-content-ltr">Published to Labs</span></label><default>…</default></data>
        <data><label><span lang="en" dir="ltr" class="mw-content-ltr">Published</span></label><default>…</default></data>
        <data><label><span lang="en" dir="ltr" class="mw-content-ltr">Last updated</span></label><default>…</default></data>
        <data><label><span lang="en" dir="ltr" class="mw-content-ltr">Version</span></label><default>…</default></data>
    </group>
</infobox>
}}|
