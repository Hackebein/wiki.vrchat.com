<noinclude><languages/></noinclude><includeonly><infobox type="World" theme="community">
	<title source="name"><default>{{#ifexist:Template:World/{{{id|}}}/name|{{World/{{{id|}}}/name}}}}</default></title>
	<image source="image"><default>{{#ifexist:Media:{{{id|}}}_imageUrl.png|[[File:{{{id|}}}_imageUrl.png]]}}</default></image>
	<group>
        <data source="author"><label>Author</label><default>{{#ifexist:Template:World/{{{id|}}}/authorName|{{World/{{{id|}}}/authorName}}}}</default></data>
        <data source="developers"><label>Developers</label></data>
        <data source="capacity"><label>Capacity</label><default>{{#ifexist:Template:World/{{{id|}}}/recommendedCapacity|{{#ifexist:Template:World/{{{id|}}}/capacity|{{World/{{{id|}}}/recommendedCapacity}} (max {{World/{{{id|}}}/capacity}})}}}}</default></data>
        <data source="platforms"><label>Platforms</label><default>{{#ifexist:Template:World/{{{id|}}}/platforms|{{World/{{{id|}}}/platforms}}}}</default></data>
        <data source="tags"><label>Tags</label><default>{{#ifexist:Template:World/{{{id|}}}/tags|{{World/{{{id|}}}/tags}}}}</default></data>
        <data source="languages"><label>Languages</label></data>
        <data source="id"><label>World Link</label>
           <format>{{World link|{{{id}}}|{{#if:{{{name|}}}|{{{name}}}|{{#ifexist:Template:World/{{{id}}}/name|{{World/{{{id}}}/name}}|{{{id}}}}}}}}}</format></data>
        <data source="previewYoutubeId"><label>Video</label>
           <format>{{YouTube|id={{{previewYoutubeId}}}|width=30%|thumb=File:{{{id}}}_previewYoutubeId.jpg}}</format>
           <default>{{#ifexist:Template:World/{{{id|}}}/previewYoutubeId|{{YouTube|id={{World/{{{id|}}}/previewYoutubeId}}|width=100%|thumb=File:{{{id|}}}_previewYoutubeId.jpg}}}}</default></data>
    </group>
    <group>
        <header>Statistics</header>
        <data source="visits"><label>Visits</label><default>{{#ifexist:Template:World/{{{id|}}}/visits|{{formatnum:{{World/{{{id|}}}/visits}}}}}}</default></data>
        <data source="favorites"><label>Favorites</label><default>{{#ifexist:Template:World/{{{id|}}}/favorites|{{formatnum:{{World/{{{id|}}}/favorites}}}}}}</default></data>
        <data source="popularity"><label>Popularity</label><default>{{#ifexist:Template:World/{{{id|}}}/popularity|{{#switch:{{World/{{{id|}}}/popularity}}|0=|1=鉂わ笍|2=鉂わ笍鉂わ笍|3=鉂わ笍鉂わ笍鉂わ笍|4=鉂わ笍鉂わ笍鉂わ笍鉂わ笍|5=鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍|6=鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍|7=鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍|8=鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍|9=鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍|10=鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍鉂わ笍}}}}</default></data>
        <data source="heat"><label>Heat</label><default>{{#ifexist:Template:World/{{{id|}}}/heat|{{#switch:{{World/{{{id|}}}/heat}}|0=|1=馃敟|2=馃敟馃敟|3=馃敟馃敟馃敟|4=馃敟馃敟馃敟馃敟|5=馃敟馃敟馃敟馃敟馃敟|6=馃敟馃敟馃敟馃敟馃敟馃敟|7=馃敟馃敟馃敟馃敟馃敟馃敟馃敟|8=馃敟馃敟馃敟馃敟馃敟馃敟馃敟馃敟|9=馃敟馃敟馃敟馃敟馃敟馃敟馃敟馃敟馃敟|10=馃敟馃敟馃敟馃敟馃敟馃敟馃敟馃敟馃敟馃敟}}}}</default></data>
    </group>
    <group>
        <header>World history</header>
        <data source="labs">
            <label>Published to Labs</label>
            <format>{{#timel:F d, Y |{{{labs}}}}}</format>
            <default>{{#ifexist:Template:World/{{{id|}}}/labsPublicationDate|{{#ifeq:{{World/{{{id|}}}/labsPublicationDate}}|none||{{#timel:F d, Y |{{World/{{{id|}}}/labsPublicationDate}}}}}}}}</default>
        </data>
        <data source="published">
            <label>Published</label>
            <format>{{#timel:F d, Y |{{{published}}}}}</format>
            <default>{{#ifexist:Template:World/{{{id|}}}/publicationDate|{{#ifeq:{{World/{{{id|}}}/publicationDate}}|none||{{#timel:F d, Y |{{World/{{{id|}}}/publicationDate}}}}}}}}</default>
        </data>
        <data source="updated"><label>Last updated</label><default>{{#ifexist:Template:World/{{{id|}}}/updated_at|{{#timel:F d, Y |{{World/{{{id|}}}/updated_at}}}}}}</default></data>
        <data source="version"><label>Version</label><default>{{#ifexist:Template:World/{{{id|}}}/version|{{World/{{{id|}}}/version}}}}</default></data>
    </group>
</infobox>{{#ifeq: {{NAMESPACENUMBER}} | 3000 | [[Category:Community Content{{#translation:}}]]}}[[Category:Worlds{{#translation:}}]]</includeonly><noinclude>{{Documentation}}</noinclude>