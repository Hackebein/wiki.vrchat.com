<noinclude><languages/></noinclude><includeonly><infobox type="World" theme="community">
	<title source="name"><default>'''Nome ausente!'''</default></title>
	<image source="image"><default>[[File:Placeholder.webp|Missing thumbnail image!]]</default></image>
	<group>
        <data source="author"><label>Autor</label><default>'''Autor ausente!'''</default></data>
        <data source="developers"><label>Desenvolvedores</label></data>
        <data source="capacity"><label>Capacidade</label></data>
        <data source="platforms"><label>Plataformas</label></data>
        <data source="tags"><label>Etiquetas</label></data>
        <data source="languages"><label>Idiomas</label></data>
        <data source="id"><label>Link para o Mundo</label>
           <default><span lang="en" dir="ltr" class="mw-content-ltr">'''Missing world ID!'''</span></default>
           <format>{{World link|{{{id}}}|{{{name}}}}}</format></data>
    </group>
    <group>
        <header>História do Mundo</header>
        <data source="labs">
            <label>Publicado no Labs</label>
            <format>{{#timel: d, F, Y | {{{labs}}} }}</format>
        </data>
        <data source="published">
            <label>Publicado</label>
            <format>{{#timel: d, F, Y | {{{published}}} }}</format>
        </data>
    </group>
</infobox>{{#ifeq: {{NAMESPACENUMBER}} | 3000 | [[Category:Community Content{{#translation:}}]]}}[[Category:Worlds{{#translation:}}]]</includeonly><noinclude>{{Documentation}}</noinclude>