<noinclude><languages/></noinclude><includeonly><infobox type="World" theme="community">
	<title source="name"><default><span lang="en" dir="ltr" class="mw-content-ltr">'''Missing name!'''</span></default></title>
	<image source="image"><default>[[File:Placeholder.webp|Missing thumbnail image!]]</default></image>
	<group>
        <data source="author"><label>Auteur</label><default><span lang="en" dir="ltr" class="mw-content-ltr">'''Missing author!'''</span></default></data>
        <data source="developers"><label>Développeurs</label></data>
        <data source="capacity"><label>Capacité</label></data>
        <data source="platforms"><label>Plateformes</label></data>
        <data source="tags"><label>Tags</label></data>
        <data source="languages"><label>Langues</label></data>
        <data source="id"><label>Lien vers le monde</label>
           <default><span lang="en" dir="ltr" class="mw-content-ltr">'''Missing world ID!'''</span></default>
           <format>{{World link|{{{id}}}|{{{name}}}}}</format></data>
    </group>
    <group>
        <header>Historique du monde</header>
        <data source="labs">
            <label>Publié dans Labs</label>
            <format>{{#timel:F d, Y|{{{labs}}}}}</format>
        </data>
        <data source="published">
            <label>Publié</label>
            <format>{{#timel:F d, Y |{{{published}}}}}</format>
        </data>
    </group>
</infobox>{{#ifeq: {{NAMESPACENUMBER}} | 3000 | [[Category:Community Content{{#translation:}}]]}}[[Category:Worlds{{#translation:}}]]</includeonly><noinclude>{{Documentation}}</noinclude>