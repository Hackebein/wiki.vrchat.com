<noinclude><languages/></noinclude><includeonly><infobox type="World" theme="official">
	<title source="name"><default>{{#ifexist:Template:World/{{{id|}}}/name|{{World/{{{id|}}}/name}}}}</default></title>
	<image source="image">
	    <caption source="imagecaption" />
	    <default>{{#ifexist:Media:{{{id|}}}_imageUrl.png|[[File:{{{id|}}}_imageUrl.png]]}}</default>
	</image>
	<group>
        <data source="developer"><label>開発者</label><default>{{#ifexist:Template:World/{{{id|}}}/authorName|{{World/{{{id|}}}/authorName}}}}</default></data>
        <data source="publisher"><label><span lang="en" dir="ltr" class="mw-content-ltr">Publisher</span></label></data>
    	<data source="designer"><label><span lang="en" dir="ltr" class="mw-content-ltr">Designer</span></label></data>
    	<data source="gen"><label><span lang="en" dir="ltr" class="mw-content-ltr">Generation</span></label></data>
        <data source="platform"><label>プラットフォーム</label><default>{{#ifexist:Template:World/{{{id|}}}/platforms|{{World/{{{id|}}}/platforms}}}}</default></data>
        <data source="themes"><label>テーマ</label></data>
        <data source="link"><label>ワールドのリンク</label><default>{{#if:{{{id|}}}|{{World link|{{{id}}}|{{#if:{{{name|}}}|{{{name}}}|{{#ifexist:Template:World/{{{id}}}/name|{{World/{{{id}}}/name}}|{{{id}}}}}}}}}}}</default></data>
        <data source="previewYoutubeId"><label>Video</label>
           <format><div style="width:248px;margin:0 auto">{{YouTube|id={{{previewYoutubeId}}}|width=248px|thumb=File:{{{id}}}_previewYoutubeId.jpg}}</div></format>
           <default>{{#ifexist:Template:World/{{{id|}}}/previewYoutubeId|<div style="width:248px;margin:0 auto">{{YouTube|id={{World/{{{id|}}}/previewYoutubeId}}|width=248px|thumb=File:{{{id|}}}_previewYoutubeId.jpg}}</div>}}</default></data>
    </group>
    <group>
        <header>ワールドの歴史</header>
        <data source="labs"><label>コミュニティラボ</label><default>{{#ifexist:Template:World/{{{id|}}}/labsPublicationDate|{{#ifeq:{{World/{{{id|}}}/labsPublicationDate}}|none||{{#timel:F d, Y |{{World/{{{id|}}}/labsPublicationDate}}}}}}}}</default></data>
        <data source="published"><label>公開日</label><default>{{#ifexist:Template:World/{{{id|}}}/publicationDate|{{#ifeq:{{World/{{{id|}}}/publicationDate}}|none||{{#timel:F d, Y |{{World/{{{id|}}}/publicationDate}}}}}}}}</default></data>
    </group>
</infobox>{{#ifeq: {{NAMESPACENUMBER}} | 0 | [[Category:Worlds{{#translation:}}]] [[Category:Official Content{{#translation:}}]]}}</includeonly><noinclude>{{Documentation}}</noinclude>