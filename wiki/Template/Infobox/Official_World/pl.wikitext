<noinclude><languages/></noinclude><includeonly><infobox type="World" theme="official">
	<title source="name"><default>{{#ifexist:Template:World/{{{id|}}}/name|{{World/{{{id|}}}/name}}}}</default></title>
	<image source="image">
	    <caption source="imagecaption" />
	    <default>{{#ifexist:Media:{{{id|}}}_imageUrl.png|[[File:{{{id|}}}_imageUrl.png]]}}</default>
	</image>
	<group>
        <data source="developer"><label>Deweloper</label><default>{{#ifexist:Template:World/{{{id|}}}/authorName|{{World/{{{id|}}}/authorName}}}}</default></data>
        <data source="publisher"><label>Publikujący</label></data>
    	<data source="designer"><label>Projektant</label></data>
    	<data source="gen"><label>Generacja</label></data>
        <data source="platform"><label>Platformy</label><default>{{#ifexist:Template:World/{{{id|}}}/platforms|{{World/{{{id|}}}/platforms}}}}</default></data>
        <data source="themes"><label>Motywy</label></data>
        <data source="link"><label>Link świata</label><default>{{#if:{{{id|}}}|{{World link|{{{id}}}|{{#if:{{{name|}}}|{{{name}}}|{{#ifexist:Template:World/{{{id}}}/name|{{World/{{{id}}}/name}}|{{{id}}}}}}}}}}}</default></data>
        <data source="previewYoutubeId"><label>Video</label>
           <format>{{YouTube|id={{{previewYoutubeId}}}|width=100%|thumb=File:{{{id}}}_previewYoutubeId.jpg}}</format>
           <default>{{#ifexist:Template:World/{{{id|}}}/previewYoutubeId|{{YouTube|id={{World/{{{id|}}}/previewYoutubeId}}|width=100%|thumb=File:{{{id|}}}_previewYoutubeId.jpg}}}}</default></data>
    </group>
    <group>
        <header>Historia</header>
        <data source="labs"><label>Laboratoria</label><default>{{#ifexist:Template:World/{{{id|}}}/labsPublicationDate|{{#ifeq:{{World/{{{id|}}}/labsPublicationDate}}|none||{{#timel:F d, Y |{{World/{{{id|}}}/labsPublicationDate}}}}}}}}</default></data>
        <data source="published"><label>Publikacja</label><default>{{#ifexist:Template:World/{{{id|}}}/publicationDate|{{#ifeq:{{World/{{{id|}}}/publicationDate}}|none||{{#timel:F d, Y |{{World/{{{id|}}}/publicationDate}}}}}}}}</default></data>
    </group>
</infobox>{{#ifeq: {{NAMESPACENUMBER}} | 0 | [[Category:Worlds{{#translation:}}]] [[Category:Official Content{{#translation:}}]]}}</includeonly><noinclude>{{Documentation}}</noinclude>