{{#switch: {{{3|rect}}}
|rect = <span style="font-size: small; border: 0.2em solid; border-color: #DDD #BBB #BBB #DDD; padding: 0.1em 0.2em; background: #EEE; white-space: nowrap; border-radius: 2px;">
<span title={{{2|{{{1}}}}}} style="color:black;">{{ucfirst:{{{1}}}}}</span>
</span>
|circle = <span style="display: inline-block;
  line-height: 0px;
  border-radius: 50%;
  border: 0.2em solid;
  border-color: #BBB;
  font-size: small;background: #EEE;">
<span title={{{2|{{{1}}}}}} style="display: inline-block;
  padding-top: 50%;
  padding-bottom: 50%;
  margin-left: 4px;
  margin-right: 4px;color:black;">{{ucfirst:{{{1}}}}}</span>
</span>
}}
<noinclude>
{{Documentation}}
</noinclude>